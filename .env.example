# ===== Domínio e ACME =====
DOMAIN=bitvar.example.com
ACME_EMAIL=contato@jaoiagro.com
# STAGING por padrão (certs não confiáveis no browser, mas sem rate-limit):
ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# PRODUÇÃO (trocar quando a stack estiver validada — e apagar o volume acme):
# ACME_CASERVER=https://acme-v02.api.letsencrypt.org/directory

# ===== Postgres =====
POSTGRES_USER=bitvar
POSTGRES_PASSWORD=troque-esta-senha-forte
POSTGRES_DB=bitvar

# DATABASE_URL é montada no compose a partir das vars acima (host = serviço "db").
# Não precisa definir aqui.

# ===== Dashboard do Traefik (basic auth) =====
# Gere o hash com: infra/scripts/gen-dashboard-auth.sh admin 'sua-senha'
# e cole em infra/traefik/dynamic.yml (no arquivo, use $ simples).

# ===== BitVar IA · Tênis (Gemini) =====
# Chave do Gemini (obrigatória p/ análise de vídeo). App sobe sem ela, mas
# /tennis/analyze responde 503 até a chave existir.
GEMINI_API_KEY=sua_chave_aqui
APP_DOMAIN=001.bitvar.illumiai.com
MAX_UPLOAD_MB=600                # validado na app, rejeita (413) antes de subir o corpo

# Persistência opcional das análises de tênis (precisa do Postgres):
TENNIS_PERSIST=false

# ===== BitVar IA · Academia (musculação; análise geral + POC de agachamento) =====
# Usa a mesma GEMINI_API_KEY/modelos acima. Exercício, variação e
# equipamento/máquina são identificados automaticamente, sem seleção manual.
# O vídeo é temporário e nunca é salvo. Persistência guarda somente
# relatório/JSON/áudio e fica desligada por padrão.
# Para habilitar, as duas variáveis abaixo são obrigatórias; o histórico exige
# Authorization: Bearer <token>. Use um segredo longo e aleatório.
ACADEMIA_PERSIST=false
# ACADEMIA_HISTORY_TOKEN=gere-um-token-longo-e-aleatorio
ACADEMIA_VIDEO_MAX_SECONDS=180   # uma série de até 3 minutos; não envie o treino inteiro
ACADEMIA_FPS=8                   # análise específica/geral no intervalo ativo
ACADEMIA_IDENTIFICATION_FPS=2    # passe genérico de identificação
# ACADEMIA_IDENTIFICATION_MEDIA_RESOLUTION=MEDIA_RESOLUTION_LOW
# ACADEMIA_ANALYSIS_MODEL=gemini-3.1-pro-preview
# Transcrição da descrição da pessoa-alvo: áudio temporário, inline e sem Files API.
# Requer ffmpeg + ffprobe no servidor; a imagem Docker já inclui as ferramentas.
# ACADEMIA_TRANSCRIPTION_MODEL=gemini-3.5-flash
# ACADEMIA_VOICE_MAX_SECONDS=30
# ACADEMIA_VOICE_MAX_UPLOAD_MB=8
# ACADEMIA_MAX_CONCURRENT_TRANSCRIPTIONS=4
# ACADEMIA_VOICE_TRANSCODE_TIMEOUT_SECONDS=20
# ACADEMIA_VOICE_REQUEST_OVERHEAD_MB=1
# ACADEMIA_NARRATIVE_THINKING_LEVEL=high
# ACADEMIA_TTS_MODEL=gemini-3.1-flash-tts-preview
# ACADEMIA_TTS_VOICE=Vindemiatrix
# ACADEMIA_MAX_UPLOAD_MB=600
# ACADEMIA_MEDIA_RESOLUTION=MEDIA_RESOLUTION_HIGH
# ACADEMIA_MAX_CONCURRENT_ANALYSES=2

# Overrides opcionais (default da análise = gemini-3.1-pro-preview, modelo "pro"):
# ANALYSIS_MODEL=gemini-3.1-pro-preview
# TRANSCRIPTION_MODEL=gemini-3.5-flash
# NARRATIVE_THINKING_LEVEL=high
# TTS_MODEL=gemini-3.1-flash-tts-preview
# TTS_VOICE=Vindemiatrix
# CLIP_MAX_SECONDS=75
# CLIP_FPS=4
# MATCH_FPS=1
